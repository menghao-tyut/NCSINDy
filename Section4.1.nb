       "Construct", " ", "nonlinear", " ", "library", " ", "matrix", " ", 
        "in", " ", "frequency", " ", "domain"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ModelLibrary", "[", "j2", "]"}], "=", 
       RowBox[{"StiffnessModel", "/.", 
        RowBox[{"Thread", "[", 
