Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Combine", " ", "residual", " ", "across", " ", "all", " ", "excitation", 
    " ", "frequencies"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Residual", "=", 
     RowBox[{"Join", "@@", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"RR1", "[", "j2", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"j2", ",", "1", ",", 
          RowBox[{"Length", "[", "OmegaList", "]"}]}], "}"}]}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Merge", " ", "physical", " ", "parameters", " ", "and", " ", "noise", 
     " ", "correction", " ", "coefficients", " ", "into", " ", "full", " ", 
     "variable", " ", "set"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Variable", "=", 
     RowBox[{"Join", "[", 
      RowBox[{"Var", ",", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Join", "[", 
           RowBox[{"CorrectCoeffjVar", "[", "j2", "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"j2", ",", "1", ",", 
            RowBox[{"Length", "[", "OmegaList", "]"}]}], "}"}]}], "]"}], "//",
         "Flatten"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Compute", " ", "Jacobian", " ", "matrix", " ", "of", " ", "residual", 
     " ", "with", " ", "respect", " ", "to", " ", "unknown", " ", 
     "variables"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"JacobiFun", "=", 
     RowBox[{"D", "[", 
      RowBox[{"Residual", ",", 
       RowBox[{"{", 
        RowBox[{"Variable", ",", "1"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", "===", "===", "===", "===", "===", "==="}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"LM", "-", 
        RowBox[{"STLS", " ", "Algorithm", " ", "Hyperparameters"}]}], "===", "===",
        "===", "===", "===", "===", "==="}], "="}]}], "*)"}], 
