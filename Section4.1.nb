          RowBox[{
           RowBox[{"A", "[", "x", "]"}], "[", "j2", "]"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Assemble", " ", "Jacobian"}], "-", 
